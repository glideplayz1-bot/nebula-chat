{
  "name": "nebula-chat",
  "version": "1.0.0",
  "description": "A modern chat application with admin controls, real-time messaging, and user management",
  "main": "server.js",
  "homepage": ".",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm install && npm run build-backend",
    "build-backend": "echo Backend ready for deployment",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "build-unix": "electron-builder --linux --mac",
    "build-android": "gradle-installer.bat & gradle build",
    "build-all": "npm run build-win && npm run build-android",
    "electron-dev": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "chat",
    "messaging",
    "realtime",
    "socket.io",
    "admin"
  ],
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "mongoose": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "body-parser": "^1.20.2",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "electron": "^latest",
    "electron-builder": "^latest",
    "electron-is-dev": "^latest"
  },
  "build": {
    "appId": "com.nebulaChat",
    "productName": "Nebula Chat",
    "files": [
      "server.js",
      "electron-main.js",
      "preload.js",
      "config/**/*",
      "models/**/*",
      "middleware/**/*",
      "routes/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nebula Chat"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
